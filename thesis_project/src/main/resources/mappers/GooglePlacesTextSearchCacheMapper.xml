<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="thesis.project.gu.infrastructure.external.google.cache.GooglePlacesTextSearchCacheMapper">

    <resultMap id="GooglePlacesTextSearchCacheMap" type="thesis.project.gu.infrastructure.external.google.cache.GooglePlacesTextSearchCache">
        <id property="cacheKey" column="cache_key"/>
        <result property="textQuery" column="text_query"/>
        <result property="city" column="city"/>
        <result property="responseJson" column="response_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByKey" resultMap="GooglePlacesTextSearchCacheMap">
        SELECT cache_key, text_query, city, response_json, created_at, updated_at
        FROM google_places_text_search_cache
        WHERE cache_key = #{cacheKey}
    </select>

    <insert id="upsert" parameterType="thesis.project.gu.infrastructure.external.google.cache.GooglePlacesTextSearchCache">
        INSERT INTO google_places_text_search_cache (
            cache_key,
            text_query,
            city,
            response_json
        ) VALUES (
            #{cacheKey},
            #{textQuery},
            #{city},
            #{responseJson}
        )
        ON DUPLICATE KEY UPDATE
            text_query = VALUES(text_query),
            city = VALUES(city),
            response_json = VALUES(response_json),
            updated_at = CURRENT_TIMESTAMP
    </insert>
</mapper>
